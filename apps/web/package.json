{
  "name": "@novaos/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "NovaOS browser workspace (Vite + React SPA).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.json && vite build",
    "preview": "vite preview --port 3000 --strictPort",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@novaos/assembler": "workspace:*",
    "@novaos/compiler": "workspace:*",
    "@novaos/cpu": "workspace:*",
    "@novaos/debugger": "workspace:*",
    "@novaos/examples": "workspace:*",
    "@novaos/shared": "workspace:*",
    "@novaos/simulator": "workspace:*",
    "@monaco-editor/react": "^4.7.0",
    "monaco-editor": "^0.52.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^5.4.21"
  }
}
