{
  "name": "@novaos/assembler",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "NovaASM parser, label resolution, bytecode emitter, and source maps.",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@novaos/cpu": "workspace:*",
    "@novaos/shared": "workspace:*"
  }
}
