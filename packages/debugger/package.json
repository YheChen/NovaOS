{
  "name": "@novaos/debugger",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Breakpoints, stepping, watches, snapshots, and timeline integration.",
  "sideEffects": false,
  "main": "./src/index.ts",
