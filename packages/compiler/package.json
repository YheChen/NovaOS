{
  "name": "@novaos/compiler",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Toy C pipeline: lexer, parser, semantic analysis, IR, codegen.",
  "sideEffects": false,
  "main": "./src/index.ts",
