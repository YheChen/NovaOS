{
  "name": "@novaos/simulator",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Runtime orchestration: boot, ticking, snapshots, and replay.",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@novaos/assembler": "workspace:*",
    "@novaos/compiler": "workspace:*",
    "@novaos/cpu": "workspace:*",
    "@novaos/events": "workspace:*",
    "@novaos/kernel": "workspace:*",
    "@novaos/memory": "workspace:*",
    "@novaos/scheduler": "workspace:*",
    "@novaos/shared": "workspace:*"
  },
  "devDependencies": {
    "@novaos/testing": "workspace:*"
  }
}
